<view class="page">
  <view class="panel">
    <view class="title">ESP32-CAM 局域网视频</view>
    <view class="subtitle">
      请输入 ESP32-CAM 在当前局域网中的 IP。小程序页面会使用抓拍轮询的方式刷新画面。
    </view>

    <input
      class="ip-input"
      placeholder="请输入摄像头 IP"
      value="{{cameraIpInput}}"
      bindinput="onIpInput"
    />

    <view class="actions">
      <button type="primary" size="mini" bindtap="saveCameraIp">保存 IP</button>
      <button size="mini" bindtap="testConnection">测试连接</button>
      <button size="mini" bindtap="refreshStream">刷新画面</button>
      <button size="mini" bindtap="previewCapture">抓拍预览</button>
    </view>

    <view class="status">{{statusText}}</view>
    <view class="url" wx:if="{{captureUrl}}">抓拍地址：{{captureUrl}}</view>
    <view class="url" wx:if="{{healthUrl}}">健康检查：{{healthUrl}}</view>
  </view>

  <view class="stream-card" wx:if="{{canPreview}}">
    <image
      class="stream-image"
      src="{{previewUrl}}"
      mode="widthFix"
      bindload="onPreviewLoad"
      binderror="onPreviewError"
      show-menu-by-longpress="{{true}}"
    />
  </view>
</view>
